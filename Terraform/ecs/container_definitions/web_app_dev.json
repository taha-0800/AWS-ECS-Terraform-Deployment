[
  {
    "name": "dev-container",
    "image": "YourContainerID.dkr.ecr.us-east-1.amazonaws.com/web-app-repository:main-latest",
    "portMappings": [
      {
        "containerPort": 8080,
        "protocol": "tcp"
      }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/web-app-dev",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }
]